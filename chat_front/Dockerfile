# Stage 1: Build
FROM node:18-alpine AS builder
WORKDIR /app

# Define ARGs for Next.js build-time variables
ARG NEXT_PUBLIC_API_URL_DEVELOPMENT
ARG NEXT_PUBLIC_API_URL_STAGING
ARG NEXT_PUBLIC_API_URL_PRODUCTION
ARG NEXT_PUBLIC_STRICT_MODE
ARG NEXT_PUBLIC_RAZORPAY_KEY_ID
ARG NEXT_PUBLIC_ENVIRONMENT
ARG NEXT_PUBLIC_KYC_REDIRECT
ARG NEXT_PUBLIC_ICANN_DOMAIN_TLDS
ARG NEXT_PUBLIC_ICANN_PRICE_INR
ARG NEXT_PUBLIC_ICANN_PRICE_USD
ARG NEXT_PUBLIC_MAX_DISK_SIZE
ARG NEXT_PUBLIC_BANDWIDTH_EXCEEDS_WARNING_PERCENT

# Set ARGs to ENVs so Next.js sees them during 'npm run build'
ENV NEXT_PUBLIC_API_URL_DEVELOPMENT=$NEXT_PUBLIC_API_URL_DEVELOPMENT \
    NEXT_PUBLIC_API_URL_STAGING=$NEXT_PUBLIC_API_URL_STAGING \
    NEXT_PUBLIC_API_URL_PRODUCTION=$NEXT_PUBLIC_API_URL_PRODUCTION \
    NEXT_PUBLIC_STRICT_MODE=$NEXT_PUBLIC_STRICT_MODE \
    NEXT_PUBLIC_RAZORPAY_KEY_ID=$NEXT_PUBLIC_RAZORPAY_KEY_ID \
    NEXT_PUBLIC_ENVIRONMENT=$NEXT_PUBLIC_ENVIRONMENT \
    NEXT_PUBLIC_KYC_REDIRECT=$NEXT_PUBLIC_KYC_REDIRECT \
    NEXT_PUBLIC_ICANN_DOMAIN_TLDS=$NEXT_PUBLIC_ICANN_DOMAIN_TLDS \
    NEXT_PUBLIC_ICANN_PRICE_INR=$NEXT_PUBLIC_ICANN_PRICE_INR \
    NEXT_PUBLIC_ICANN_PRICE_USD=$NEXT_PUBLIC_ICANN_PRICE_USD \
    NEXT_PUBLIC_MAX_DISK_SIZE=$NEXT_PUBLIC_MAX_DISK_SIZE \
    NEXT_PUBLIC_BANDWIDTH_EXCEEDS_WARNING_PERCENT=$NEXT_PUBLIC_BANDWIDTH_EXCEEDS_WARNING_PERCENT

COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# Stage 2: Run
FROM node:18-alpine
WORKDIR /app
COPY --from=builder /app ./

EXPOSE 3000
CMD ["npm", "start", "--", "-H", "0.0.0.0"]