FROM node:18-alpine

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

ARG NEXT_PUBLIC_API_URL_DEVELOPMENT
ARG NEXT_PUBLIC_API_URL_STAGING
ARG NEXT_PUBLIC_API_URL_PRODUCTION
ARG NEXT_PUBLIC_STRICT_MODE
ARG NEXT_PUBLIC_RAZORPAY_KEY_ID
ARG NEXT_PUBLIC_ENVIRONMENT
ARG NEXT_PUBLIC_KYC_REDIRECT
ARG NEXT_PUBLIC_ICANN_DOMAIN_TLDS
ARG NEXT_PUBLIC_ICANN_PRICE_INR
ARG NEXT_PUBLIC_ICANN_PRICE_USD
ARG NEXT_PUBLIC_MAX_DISK_SIZE
ARG NEXT_PUBLIC_BANDWIDTH_EXCEEDS_WARNING_PERCENT

ENV NEXT_PUBLIC_API_URL_DEVELOPMENT=$NEXT_PUBLIC_API_URL_DEVELOPMENT
ENV NEXT_PUBLIC_API_URL_STAGING=$NEXT_PUBLIC_API_URL_STAGING
ENV NEXT_PUBLIC_API_URL_PRODUCTION=$NEXT_PUBLIC_API_URL_PRODUCTION
ENV NEXT_PUBLIC_STRICT_MODE=$NEXT_PUBLIC_STRICT_MODE
ENV NEXT_PUBLIC_RAZORPAY_KEY_ID=$NEXT_PUBLIC_RAZORPAY_KEY_ID
ENV NEXT_PUBLIC_ENVIRONMENT=$NEXT_PUBLIC_ENVIRONMENT
ENV NEXT_PUBLIC_KYC_REDIRECT=$NEXT_PUBLIC_KYC_REDIRECT
ENV NEXT_PUBLIC_ICANN_DOMAIN_TLDS=$NEXT_PUBLIC_ICANN_DOMAIN_TLDS
ENV NEXT_PUBLIC_ICANN_PRICE_INR=$NEXT_PUBLIC_ICANN_PRICE_INR
ENV NEXT_PUBLIC_ICANN_PRICE_USD=$NEXT_PUBLIC_ICANN_PRICE_USD
ENV NEXT_PUBLIC_MAX_DISK_SIZE=$NEXT_PUBLIC_MAX_DISK_SIZE
ENV NEXT_PUBLIC_BANDWIDTH_EXCEEDS_WARNING_PERCENT=$NEXT_PUBLIC_BANDWIDTH_EXCEEDS_WARNING_PERCENT

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]